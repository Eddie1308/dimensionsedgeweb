# Database
DATABASE_URL="mysql://user:password@localhost:3306/dimensionsedge"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# Uploads — set UPLOAD_DIR_ABS to an absolute path on the server so uploads
# work correctly under Next.js standalone (where process.cwd() may differ).
UPLOAD_DIR_ABS="/www/wwwroot/dimensionsedgeest.com/public/uploads"
MAX_UPLOAD_SIZE_MB="10"

# Admin bootstrap (used by seed script only)
SEED_ADMIN_EMAIL="admin@dimensionsedge.sa"
SEED_ADMIN_PASSWORD="change-me-after-first-login"
